{
  "manifest_version": 3,
  "name": "Random Tab Refresher",
  "version": "1.0",
  "description": "Refreshes the current tab at random intervals between 1-5 minutes with a countdown badge.",
  "permissions": ["tabs", "alarms", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon128.svg",
      "128": "icons/icon128.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon128.svg",
    "128": "icons/icon128.svg"
  }
}
